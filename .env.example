# =========================================
# Customer Manager 环境配置模板
# =========================================
# 使用方法：
# 1. 复制此文件为 `.env`（根目录）
# 2. 根据实际环境修改配置值
# 3. 后端配置在 `backend/.env` 中单独管理
# =========================================

# -----------------------------------------
# 数据库配置
# -----------------------------------------
DB_TYPE=postgresql
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=customer_manager
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------
# JWT 认证配置
# -----------------------------------------
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=2

# -----------------------------------------
# 环境配置
# -----------------------------------------
ENVIRONMENT=development

# -----------------------------------------
# 测试数据库配置
# 注意：测试环境使用独立的 PostgreSQL 数据库
# 需要预先创建：createdb -U postgres customer_manager_test
# -----------------------------------------
TEST_DB_TYPE=postgresql
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres
TEST_DB_NAME=customer_manager_test
TEST_DB_HOST=localhost
TEST_DB_PORT=5432

# -----------------------------------------
# 分页配置
# -----------------------------------------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
