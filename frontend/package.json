    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "less": "^4.5.1",
    "less-loader": "^12.3.1",
    "sass-embedded": "^1.97.3",
