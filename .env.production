# =========================================
# Customer Manager 生产环境配置
# =========================================

# -----------------------------------------
# 数据库配置
# -----------------------------------------
DB_TYPE=postgresql
DB_USER=customer_manager
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_NAME=customer_manager
DB_HOST=postgres
DB_PORT=5432

# -----------------------------------------
# JWT 认证配置
# -----------------------------------------
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=2

# -----------------------------------------
# 环境配置
# -----------------------------------------
ENVIRONMENT=production

# -----------------------------------------
# 分页配置
# -----------------------------------------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# -----------------------------------------
# 日志配置
# -----------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
